        "-pi-package/skills/debug-helper/SKILL.md",
        "-pi-package/skills/neubrutalism/SKILL.md",
        "-pi-package/skills/quick-setup/SKILL.md",
        "+pi-package/skills/context7/SKILL.md"
      ],
      "extensions": [
        "-pi-package/extensions/bg-process.ts",
        "-pi-package/extensions/custom-footer.ts",
        "-pi-package/extensions/ant-colony/index.ts",
        "-pi-package/extensions/auto-update.ts",
        "-pi-package/extensions/auto-session-name.ts",
        "-pi-package/extensions/compact-header.ts",
        "-pi-package/extensions/git-guard.ts",
        "-pi-package/extensions/safe-guard.ts"
      ]
    },
    {
      "source": "npm:lsp-pi@1.0.4",
