    {
      "source": "npm:@ifi/oh-pi-ant-colony",
      "extensions": [
        "+extensions/ant-colony/index.ts"
      ]
    },
    "npm:@mjakl/pi-dark-or-light",
    "npm:@benvargas/pi-exa-mcp",
    "npm:pi-context-saver",
    {
      "source": "npm:pi-zellij",
      "extensions": [
        "-extensions/index.ts"
      ],
      "skills": [
        "-skills/code-review/SKILL.md"
      ],
      "prompts": [
        "-prompts/review-diff.md",
        "-prompts/review.md"
      ]
    },
    "npm:@ogulcancelik/pi-spar",
    {
      "source": "npm:@ogulcancelik/pi-minimal-footer",
